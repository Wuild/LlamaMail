{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"declaration": true,
		"rootDir": "./src",
		"outDir": "./dist",
		"strict": true,
		"skipLibCheck": true,
		"types": ["node", "electron"]
	},
	"include": ["src", "src/*.d.ts"],
	"exclude": ["dist", "node_modules"]
}
